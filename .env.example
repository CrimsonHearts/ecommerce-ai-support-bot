# AI Provider (openai, kimi, or local)
AI_PROVIDER=kimi

# For Kimi/Moonshot
KIMI_API_KEY=your-kimi-api-key-here

# For OpenAI (alternative)
# OPENAI_API_KEY=sk-your-openai-key-here

# For Local Models (Ollama, etc.)
# AI_PROVIDER=local
# LOCAL_API_URL=http://localhost:11434/v1/chat/completions
# LOCAL_MODEL=llama2

# Store Configuration
STORE_NAME=TechGear

# WhatsApp Configuration
WHATSAPP_ENABLED=true
WHATSAPP_WHITELIST=+6583886330,+1234567890,+9876543210
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token
WHATSAPP_ACCESS_TOKEN=your-whatsapp-business-access-token
WHATSAPP_BUSINESS_PHONE_ID=your-business-phone-id
